  +-----+-----+-----+-----+---
  | #0  | #1  | #2  | #3  | ...
  |empty|ship |enemy|empty|
  +-----+-----+-----+-----+---

  Your code says: spr(1, 60, 100)
  PICO-8 looks up slot 1, finds your ship,
  draws it at position (60, 100) on screen.`;

	const diagramLoop = `_init()   called ONCE when the game starts
    |
    v
_update() ---> called 30 TIMES PER SECOND
    |           (read input, move things)
    v
_draw()  ---> called 30 TIMES PER SECOND
    |           (draw everything to screen)
    |
    +--- loops back to _update() forever`;

	const diagramTables = `bullets = {}                   -- empty list

add(bullets, {x=10, y=90})    -- list now has 1 item
add(bullets, {x=30, y=80})    -- list now has 2 items

bullets:
  +------------------+
  | {x=10, y=90}     | item 1
  | {x=30, y=80}     | item 2
  +------------------+

for b in all(bullets) do       -- visits each item
  b.y -= 4                     -- moves each one up
end

del(bullets, item)             -- removes one item`;

	const diagramCollision = `  bullet (b)    enemy (e)
      *          +--+
                 |  |
                 +--+

  distance in x:  abs(b.x - e.x)
  distance in y:  abs(b.y - e.y)

  if BOTH distances are small (say, less than 6),
  the objects are overlapping.

  abs() gives you the distance without caring
  about direction:
    abs(10 - 7) = 3
    abs(7 - 10) = 3`;

	const diagramState = `game_over = false
    |
    v
+-- PLAYING --------+
|   move ship       |
|   shoot           |
|   spawn           |
+--------+----------+
         |
   enemy reaches bottom
         |
         v
   game_over = true
         |
         v
+-- GAME OVER ------+
|   show score      |
|   wait for        |
|   restart         |
+-------------------+`;
</script>

